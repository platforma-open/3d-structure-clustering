{
  "name": "@platforma-open/milaboratories.3d-structure-clustering.software",
  "version": "1.0.2",
  "type": "module",
  "description": "Block Software",
  "scripts": {
    "do-pack": "shx rm -f *.tgz && pl-pkg build && pnpm pack && shx mv platforma-open*.tgz package.tgz",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "build": "pl-pkg build",
    "prepublishOnly": "pl-pkg prepublish"
  },
  "block-software": {
    "artifacts": {
      "py-archive": {
        "type": "python",
        "registry": "platforma-open",
        "environment": "@platforma-open/milaboratories.runenv-python-3:3.12.10",
        "dependencies": {
          "toolset": "pip",
          "requirements": "requirements.txt"
        },
        "root": "./src"
      }
    },
    "entrypoints": {
      "process-results": {
        "binary": {
          "artifact": "py-archive",
          "cmd": [
            "python",
            "{pkg}/process_results.py"
          ]
        }
      },
      "create-empty-files": {
        "binary": {
          "artifact": "py-archive",
          "cmd": [
            "python",
            "{pkg}/create_empty_files.py"
          ]
        }
      },
      "filter-pdbs": {
        "binary": {
          "artifact": "py-archive",
          "cmd": [
            "python",
            "{pkg}/filter_pdbs.py"
          ]
        }
      },
      "extract-cdrh3": {
        "binary": {
          "artifact": "py-archive",
          "cmd": [
            "python",
            "{pkg}/extract_cdrh3.py"
          ]
        }
      }
    }
  },
  "devDependencies": {
    "@platforma-open/milaboratories.runenv-python-3": "catalog:",
    "@platforma-sdk/package-builder": "catalog:"
  }
}
